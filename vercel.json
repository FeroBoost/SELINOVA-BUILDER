{
  "version": 2,
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "BASE_PATH=/ pnpm --filter @workspace/selinova-web run build",
  "outputDirectory": "artifacts/selinova-web/dist/public",
  "framework": null,
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
